<LoginScreen>:
    name: "login_screen"

    MDFloatLayout:
        MDLabel:
            text: "Вход"
            halign: "center"
            font_style: "H4"
            pos_hint: {"center_x": 0.5, "center_y": 0.85}

        MDTextField:
            id: email_field
            hint_text: "Email"
            pos_hint: {"center_x": 0.5, "center_y": 0.65}
            size_hint_x: 0.8
            mode: "rectangle"

        MDTextField:
            id: password_field
            hint_text: "Пароль"
            password: True
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            size_hint_x: 0.8
            mode: "rectangle"

        MDRaisedButton:
            text: "Войти"
            pos_hint: {"center_x": 0.5, "center_y": 0.45}
            size_hint_x: 0.8
            on_release: root.do_login()

        MDFlatButton:
            text: "Нет аккаунта? Зарегистрироваться"
            pos_hint: {"center_x": 0.5, "center_y": 0.38}
            on_release: app.root.current = "register_screen"