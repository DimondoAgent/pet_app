#             pos_hint: {"center_y": 0.6}
#         MDTextButton:
#             text: "Settings"
#             pos_hint: {"center_x": 0.5, "center_y": 0.4}
#             on_release: app.change_screen("settings_screen")

<PetProfileScreen@MDScreen>:
    name: "pet_profile"

    MDFloatLayout:

        # ===== HEADER =====
        MDLabel:
            text: "Профиль питомца"
            halign: "center"
            font_style: "H6"
            pos_hint: {"center_y": 0.95}

        # ===== PET IMAGE =====
        FitImage:
            source: "pet_placeholder.png"  
            size_hint: None, None
            size: dp(120), dp(120)
            pos_hint: {"center_x": 0.5, "center_y": 0.75}
            radius: [60,]

        # ===== PET NAME =====
        MDLabel:
            id: name_label
            text: "Мурзик"
            halign: "center"
            font_style: "H5"
            pos_hint: {"center_y": 0.63}

        # ===== PET DESCRIPTION =====
        MDTextField:
            id: description_field
            hint_text: "Опишите вашего питомца (порода, возраст, особенности)"
            mode: "fill"
            size_hint_x: 0.85
            pos_hint: {"center_x": 0.5, "center_y": 0.50}
            multiline: True
            height: dp(100)

        # ===== BUTTONS SECTION =====
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(10)
            size_hint_x: 0.8
            size_hint_y: None
            height: dp(200)
            pos_hint: {"center_x": 0.5, "center_y": 0.25}

            MDRaisedButton:
                text: "Редактировать профиль"
                md_bg_color: 0.2, 0.6, 1, 1
                # on_release: app.edit_pet_profile()

            MDRaisedButton:
                text: "Медицинская информация"
                md_bg_color: 0.9, 0.5, 0.2, 1
                # on_release: app.open_medical_info()

            MDRaisedButton:
                text: "Информация о владельце"
                md_bg_color: 0.3, 0.7, 0.3, 1
                # on_release: app.open_owner_info()

        # ===== NAVIGATION BUTTON =====
       BoxLayout:
            size_hint_y: None
            height: dp(60)
            canvas.before:
                Color:
                    rgba: 0.98, 0.98, 0.98, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Главная"
                background_color: 0, 0, 0, 0
                color: 0.5, 0.5, 0.5, 1
                on_release: app.change_screen("main_screen")

            Button:
                text: "Карта"
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                on_release: app.change_screen("map_screen")

            Button:
                text: "Питомцы"
                background_color: 0, 0, 0, 0
                color: 0.5, 0.5, 0.5, 1
                on_release: app.change_screen("service")

            Button:
                text: "Чат"
                background_color: 0, 0, 0, 0
                color: 0.5, 0.5, 0.5, 1
                on_release: app.change_screen("requests")
